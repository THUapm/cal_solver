# MathSolver 环境变量模板
# 复制本文件为 .env 并填入真实值（.env 已被 .gitignore 排除，不入仓）：
#   cp .env.example .env   (Linux/Mac)
#   copy .env.example .env (Windows)

# ===== LLM API 配置 =====
# 兼容 OpenAI 协议的 API 网关地址
API_BASE=https://api.openai.com/v1

# 你的 API key（必填，缺失时应用启动会立即报错并退出）
# ⚠️ 不要把真实 key 提交到 git！本文件中的占位符仅作示例。
API_KEY=sk-REPLACE-ME-WITH-YOUR-REAL-KEY

# ===== 模型选择 =====
# Vision 模型：用于读图（数学题目 / 学生解答 OCR），需要支持视觉输入
VISION_MODEL_NAME=gpt-4o

# Solver 模型：用于生成解题推理 + 代码执行循环（不需要视觉能力）
SOLVER_MODEL_NAME=gpt-3.5-turbo

# ===== LLM 调用可靠性 =====
# 单次请求超时（秒）
LLM_TIMEOUT=60

# 可重试错误（连接错误 / 超时 / 429 限流）的最大重试次数
LLM_MAX_RETRIES=3

# 退避基础秒数（指数退避：1s, 2s, 4s, ...）
LLM_RETRY_BACKOFF=1.0

# ===== MCP 配置 =====
# MCP Server 配置文件路径（绝对路径或相对项目根目录的相对路径）
# 文件本身在 .gitignore 中不入仓；本地调试需自行维护
MCP_SERVERS=config/mcp_servers.json
